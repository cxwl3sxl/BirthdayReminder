{
  "name": "birthday-reminder-electron",
  "version": "1.0.0",
  "description": "生日提醒桌面应用 - Electron版",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win"
  },
  "dependencies": {
    "antd": "^5.24.0",
    "better-sqlite3": "^11.7.0",
    "dayjs": "^1.11.13",
    "electron-log": "^5.3.2",
    "electron-store": "^11.0.2",
    "exceljs": "^4.4.0",
    "pinyin": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.2",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.birthdayreminder.app",
    "productName": "生日提醒",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "portable"
      ]
    },
    "portable": {
      "artifactName": "${productName}.exe"
    }
  }
}
